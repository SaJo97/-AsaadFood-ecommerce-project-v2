# Set Up Gmail (Example):
# Go to Gmail settings > Security > 2-Step Verification > App Passwords.
# Generate an app password (e.g., "abcdefghijklmnop")—use this as EMAIL_PASS.
# Set EMAIL_USER=yourgmail@gmail.com and ADMIN_EMAIL=support@yourcompany.com.

#yourgmail@gmail.com
EMAIL_USER=

#yourapppassword  - Generate this in Gmail settings
EMAIL_PASS=

#support@yourcompany.com  - Where messages are sent
ADMIN_EMAIL=